                    ),
                    title: None,
                    length: None,
                    hreflang: None,
                },
                Link {
                    href: Url(
                        "https://blog.dshr.org/2026/04/dormant-digital-assets.html",
                    ),
                    rel: Some(
                        "alternate",
                    ),
                    link_type: Some(
                        MimeType(
                            "text/html",
