                    ),
                    title: None,
                    length: None,
                    hreflang: None,
                },
                Link {
                    href: Url(
                        "https://www.blogger.com/feeds/4503292949532760618/posts/default/8206523305815663754",
                    ),
                    rel: Some(
                        "self",
                    ),
                    link_type: Some(
                        MimeType(
