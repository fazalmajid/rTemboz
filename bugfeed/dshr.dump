            title: Some(
                "Mind The GAAP Again",
            ),
            title_detail: Some(
                TextConstruct {
                    value: "",
                    content_type: Text,
                    language: None,
                    base: None,
                },
            ),
            link: Some(
                "https://blog.dshr.org/2026/02/mind-gaap-again.html",
            ),
            links: [
                Link {
                    href: Url(
                        "https://blog.dshr.org/feeds/7327770860154541247/comments/default",
                    ),
                    rel: Some(
                        "replies",
