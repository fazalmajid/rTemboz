	<item>
		<title>Resistance</title>
		<pubDate>Sat, 10 May 2025 18:21:00 +0900</pubDate>
		<guid isPermaLink="false">583F6655-5D8B-40F9-B836-6194F17CA9D7</guid>
		<link>https://lmnt.me/blog/wallpapers/resistance.html</link>
		<dc:creator>Louie Mantia</dc:creator>
		<description><![CDATA[
