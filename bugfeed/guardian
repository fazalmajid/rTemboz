      <pubDate>Fri, 22 May 2026 09:00:41 GMT</pubDate>
      <guid>https://www.theguardian.com/thefilter/2025/feb/06/best-mattress</guid>
      <media:content width="140" url="https://i.guim.co.uk/img/media/116587c16c2e84de3d28e63ff28278866cf3cbd8/0_0_2545_1527/master/2545.jpg?width=140&amp;quality=85&amp;auto=format&amp;fit=max&amp;s=4c2274433b171fd3ab0be1dd68c80cc4">
